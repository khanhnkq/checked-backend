# ============================================================
# Environment variables template for checked-backend
# Copy this file to .env and fill in your own values.
# The .env file is listed in .gitignore and will NOT be committed.
# ============================================================

# ── Database (PostgreSQL) ─────────────────────────────────
DB_NAME=locket_clone
DB_USER=postgres
DB_PASS=postgres
DB_URL=jdbc:postgresql://localhost:5432/locket_clone

# ── JWT ──────────────────────────────────────────────────
# Generate a strong random base64 secret, e.g.:
#   openssl rand -base64 64
JWT_SECRET=change-me-to-a-strong-base64-secret
JWT_EXPIRATION_MS=86400000

# ── Email / SMTP ─────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
# MAIL_FROM defaults to MAIL_USERNAME if not set
# MAIL_FROM=your-email@gmail.com

# ── Cloudinary (image upload) ────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
